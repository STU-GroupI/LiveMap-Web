@using LiveMapDashboard.Web.Models.Suggestion;
@model SuggestionFormViewModel

<div class="p-4 relative z-10 bg-white border border-gray-200 rounded-xl md:p-10 dark:bg-neutral-900 dark:border-neutral-700">
    <div class="mb-2">
        <div class="max-w-sm">
            <label for="textarea-label" class="block text-sm font-medium mb-2">User request for change #@Model.RfcId</label>
            <textarea id="textarea-label" class="py-2 px-3 sm:py-3 sm:px-4 block w-full border-gray-200 rounded-lg sm:text-sm focus:border-blue-500 focus:ring-blue-500 disabled:opacity-50 disabled:pointer-events-none"
                rows="3" 
                placeholder="There was no message given..." 
                disabled
            >
                @Model.Message
            </textarea>
        </div>
    </div>
</div>